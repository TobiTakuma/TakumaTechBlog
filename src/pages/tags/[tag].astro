---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const uniqueTags = new Set<string>();
  allPosts.forEach((post) => {
    post.data.tags?.forEach((tag) => uniqueTags.add(tag));
  });

  return Array.from(uniqueTags).map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags?.includes(tag)
    );
    return {
      params: { tag },
      props: { tag, posts: filteredPosts },
    };
  });
}

const { tag, posts } = Astro.props as { tag: string; posts: CollectionEntry<'blog'>[] };

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getPostUrl(post: CollectionEntry<'blog'>) {
  return post.data.url
    ? `/${post.data.url}/`
    : `/blog/${post.id.replace(/\.md$/, '')}/`;
}
---

<BaseLayout title={`Tag: ${tag}`}>
  <h1 class="lang-en">Posts tagged "{tag}"</h1>
  <h1 class="lang-ja">タグ「{tag}」の記事一覧</h1>

  <ul>
    {posts.map((post) => (
      <li>
        <a href={getPostUrl(post)}>
          <span class="lang-en">{post.data.title_en ?? post.data.title}</span>
          <span class="lang-ja">{post.data.title}</span>
        </a>
        <span style="font-size: 0.8em; margin-left: 8px;">
          ({post.data.pubDate.toLocaleDateString('ja-JP')})
        </span>
      </li>
    ))}
  </ul>

  <p>
    <span class="lang-en"><a href="/tags/">← All Tags</a></span>
    <span class="lang-ja"><a href="/tags/">← すべてのタグ一覧へ</a></span>
  </p>
</BaseLayout>
