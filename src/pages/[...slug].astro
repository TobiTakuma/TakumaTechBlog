---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const slugPath = post.data.url ?? `blog/${post.id.replace(/\.md$/, '')}`;
    return {
      params: { slug: slugPath },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const titleEn = post.data.title_en ?? post.data.title;
---
<Layout title={titleEn}>
  <article>
    <h1 class="lang-en">{titleEn}</h1>
    <h1 class="lang-ja">{post.data.title}</h1>

    <p>{post.data.pubDate.toLocaleDateString('ja-JP')}</p>

    {post.data.tags && post.data.tags.length > 0 && (
      <p>
        Tags: {post.data.tags.map((tag, i) => (
          <span>
            <a href={`/tags/${tag}`}>{tag}</a>
            {i < post.data.tags!.length - 1 ? ', ' : ''}
          </span>
        ))}
      </p>
    )}

    <hr />
    <Content />
  </article>

  <p>
    <span class="lang-en"><a id="back-link-en" href="/blog">← Back to blog</a></span>
    <span class="lang-ja"><a id="back-link-ja" href="/blog">← 記事一覧へ</a></span>
  </p>
</Layout>

<script>
  // 来た元がブログ一覧ページならその URL を保存・復元する
  const referrer = document.referrer;
  if (referrer && new URL(referrer).pathname.startsWith('/blog')) {
    sessionStorage.setItem('blogBackUrl', new URL(referrer).pathname);
  }
  const backUrl = sessionStorage.getItem('blogBackUrl') ?? '/blog';
  document.getElementById('back-link-en')!.setAttribute('href', backUrl);
  document.getElementById('back-link-ja')!.setAttribute('href', backUrl);
</script>
