---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort((a, b) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(sortedPosts, { pageSize: 5 });
};

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };

function getPostUrl(post: CollectionEntry<'blog'>) {
  return post.data.url
    ? `/${post.data.url}/`
    : `/blog/${post.id.replace(/\.md$/, '')}/`;
}
---

<BaseLayout title="Blog">
  <h1>Blog</h1>
  <p>{page.start + 1}–{page.end + 1} of {page.total} posts</p>

  <ul>
    {page.data.map((post: CollectionEntry<'blog'>) => (
      <li>
        <a href={getPostUrl(post)}>
          <span class="lang-en">{post.data.title_en ?? post.data.title}</span>
          <span class="lang-ja">{post.data.title}</span>
        </a>
        <span style="font-size: 0.8em; margin-left: 8px;">
          {post.data.pubDate.toLocaleDateString('ja-JP')}
        </span>
      </li>
    ))}
  </ul>

  <nav aria-label="Pagination">
    {page.url.prev ? (
      <a href={page.url.prev}>← Prev</a>
    ) : (
      <span style="color: gray;">← Prev</span>
    )}
    <span style="margin: 0 1em;">
      {page.currentPage} / {page.lastPage}
    </span>
    {page.url.next ? (
      <a href={page.url.next}>Next →</a>
    ) : (
      <span style="color: gray;">Next →</span>
    )}
  </nav>
</BaseLayout>
