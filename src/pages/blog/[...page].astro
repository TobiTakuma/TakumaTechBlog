---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Layout.astro';
import { getReadingTime } from '../../utils/readingTime';
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort((a, b) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(sortedPosts, { pageSize: 5 });
};

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };

function getPostUrl(post: CollectionEntry<'blog'>) {
  return post.data.url
    ? `/${post.data.url}/`
    : `/blog/${post.id.replace(/\.md$/, '')}/`;
}
---

<BaseLayout title="Blog">
  <h1>Blog</h1>
  <p style="color: var(--color-text-muted); font-size: 0.9rem; font-family: var(--font-sans);">
    {page.start + 1}–{page.end + 1} of {page.total} posts
  </p>

  <ul class="post-list">
    {page.data.map((post: CollectionEntry<'blog'>) => (
      <li>
        <a href={getPostUrl(post)} class="post-link">
          <div class="post-title">
            <span class="lang-en">{post.data.title_en ?? post.data.title}</span>
            <span class="lang-ja">{post.data.title}</span>
          </div>
          <div class="post-meta">
            <span>{post.data.pubDate.toLocaleDateString('en-CA')}</span>
            <span class="dot">·</span>
            <span class="lang-en">{getReadingTime(post.body ?? '').en} min read</span>
            <span class="lang-ja">{getReadingTime(post.body ?? '').ja} 分で読める</span>
            {post.data.tags && post.data.tags.length > 0 && (
              <Fragment>
                <span class="dot">·</span>
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </Fragment>
            )}
          </div>
        </a>
      </li>
    ))}
    {/* 不足分を透明な行で埋め、全ページのリスト高さを揃える（ページネーション位置を固定）。
        実際の行と同じ post-title / post-meta 構造にして高さを一致させる */}
    {Array.from({ length: page.size - page.data.length }).map(() => (
      <li class="placeholder" aria-hidden="true">
        <span class="post-link">
          <div class="post-title">&nbsp;</div>
          {/* 実記事はタグの pill（枠線+余白）で meta 行が少し高くなるので、
              プレースホルダにも同じ pill を透明で入れて高さをぴったり合わせる */}
          <div class="post-meta"><span class="tag">&nbsp;</span></div>
        </span>
      </li>
    ))}
  </ul>

  <nav aria-label="Pagination" style="display: flex; align-items: center; gap: 1rem; margin-top: 2rem; font-family: var(--font-sans); font-size: 0.9rem;">
    {page.url.first ? (
      <a href={page.url.first}>« First</a>
    ) : (
      <span style="color: var(--color-text-muted);">« First</span>
    )}
    {page.url.prev ? (
      <a href={page.url.prev}>← Prev</a>
    ) : (
      <span style="color: var(--color-text-muted);">← Prev</span>
    )}
    <span style="color: var(--color-text-muted);">
      {page.currentPage} / {page.lastPage}
    </span>
    {page.url.next ? (
      <a href={page.url.next}>Next →</a>
    ) : (
      <span style="color: var(--color-text-muted);">Next →</span>
    )}
    {page.url.last ? (
      <a href={page.url.last}>Last »</a>
    ) : (
      <span style="color: var(--color-text-muted);">Last »</span>
    )}
  </nav>
</BaseLayout>
