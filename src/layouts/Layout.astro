---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const siteDescription = description ?? "Notes, discoveries, and writings by Takuma Toiyama.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- 説明文 -->
    <meta name="description" content={siteDescription} />

    <!-- OGP (SNS共有時のカード表示用) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />

    <!-- RSS フィード -->
    <link rel="alternate" type="application/rss+xml" title="TakumaTechBlog" href="/rss.xml" />

    <!-- ちらつき防止: DOMレンダリング前に言語クラスを付与 -->
    <script is:inline>
      if (sessionStorage.getItem('lang') === 'ja') document.documentElement.classList.add('ja');
    </script>
  </head>
  <body>
    <!-- 読書進捗バー -->
    <div id="progress"></div>

    <nav>
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/tags">Tags</a>
      <a href="/about">About</a>
      <div class="nav-actions">
        <button class="icon-btn" id="lang-toggle" title="Toggle language" aria-label="Toggle language">JA</button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <a href="https://github.com/TobiTakuma" title="GitHub" target="_blank" rel="noopener">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.1.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"/></svg>
        GitHub
      </a>
      <a href="/rss.xml" title="RSS">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A19.56 19.56 0 0 1 23.56 24h-2.83A16.74 16.74 0 0 0 4 7.27V4.44zm0 5.66a13.9 13.9 0 0 1 13.9 13.9h-2.83A11.07 11.07 0 0 0 4 12.93V10.1z"/></svg>
        RSS
      </a>
      <span class="spacer">© 2026 Takuma Toiyama</span>
    </footer>

    <script>
      // 読書進捗バー
      const progress = document.getElementById('progress');
      if (progress) {
        const updateProgress = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          progress.style.width = max > 0 ? (h.scrollTop / max * 100) + '%' : '0';
        };
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
      }

      // 言語切り替え
      const root = document.documentElement;
      function updateLangButton() {
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = root.classList.contains('ja') ? 'EN' : 'JA';
      }
      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        root.classList.toggle('ja');
        sessionStorage.setItem('lang', root.classList.contains('ja') ? 'ja' : 'en');
        updateLangButton();
      });
      updateLangButton();

      // コードブロックのコピーボタン（全 pre に自動付与）
      document.querySelectorAll('article pre').forEach((pre) => {
        if (pre.querySelector('.copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.innerText ?? pre.innerText;
          try {
            await navigator.clipboard.writeText(code);
            btn.textContent = 'Copied';
            btn.classList.add('copied');
            setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
          } catch (e) { /* noop */ }
        });
        pre.appendChild(btn);
      });
    </script>
  </body>
</html>
