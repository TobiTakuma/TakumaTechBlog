---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- ちらつき防止: DOMレンダリング前に言語クラスを付与 -->
    <script is:inline>
      if (sessionStorage.getItem('lang') === 'ja') document.documentElement.classList.add('ja');
    </script>
    <!-- is:global でスロット内の要素にも適用 -->
    <style is:global>
      /* デフォルト: 英語表示 */
      .lang-ja, section[lang="ja"] { display: none; }

      /* 日本語モード */
      html.ja .lang-en, html.ja section[lang="en"] { display: none; }
      html.ja .lang-ja, html.ja section[lang="ja"] { display: revert; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Home</a> |
      <a href="/blog">Blog</a> |
      <a href="/tags">Tags</a> |
      <button id="lang-toggle"></button>
    </nav>
    <hr />
    <main>
      <slot />
    </main>
    <script>
      function updateButton() {
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = document.documentElement.classList.contains('ja') ? 'English' : '日本語';
      }

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        document.documentElement.classList.toggle('ja');
        sessionStorage.setItem('lang', document.documentElement.classList.contains('ja') ? 'ja' : 'en');
        updateButton();
      });

      updateButton();
    </script>
  </body>
</html>
