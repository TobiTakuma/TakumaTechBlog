---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- ちらつき防止: DOMレンダリング前に言語クラスを付与 -->
    <script is:inline>
      if (sessionStorage.getItem('lang') === 'ja') document.documentElement.classList.add('ja');
    </script>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/tags">Tags</a>
      <button id="lang-toggle"></button>
    </nav>
    <main>
      <slot />
    </main>
    <script>
      function updateButton() {
        const btn = document.getElementById('lang-toggle');
        if (btn) btn.textContent = document.documentElement.classList.contains('ja') ? 'Read in English' : 'Read in Japanese';
      }

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        document.documentElement.classList.toggle('ja');
        sessionStorage.setItem('lang', document.documentElement.classList.contains('ja') ? 'ja' : 'en');
        updateButton();
      });

      updateButton();
    </script>
  </body>
</html>
